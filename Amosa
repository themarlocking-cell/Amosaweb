<script>
// ── DATA ──
const INSTAGRAM_URL = 'https://www.instagram.com/amosa_suisse/';

const products = [
  { id:1, name:'Cookie Lotus Noir', desc:'Pâte de spéculoos noir, pépites de chocolat noir fondant. Intense et irrésistible.', price:3.50, icon:'🍪', bg:'bg-lotus', cat:'lotus', badge:'fav', stars:5 },
  { id:2, name:'Cookie Lotus Blanc', desc:'Spéculoos blanc, chocolat blanc crémeux. Douceur absolue en chaque bouchée.', price:3.50, icon:'🤍', bg:'bg-lotus-w', cat:'lotus', badge:'', stars:5 },
  { id:3, name:'Cookie Lacasitos', desc:'Généreusement garni de M&M\'s colorés et lacasitos. Festif et délicieux.', price:3.80, icon:'🌈', bg:'bg-lacasito', cat:'special', badge:'fav', stars:5 },
  { id:4, name:'Cookie Fleurs', desc:'Cookie décoré de fleurs en sucre, élégant et romantique. Parfait en cadeau.', price:4.00, icon:'🌸', bg:'bg-flores', cat:'special', badge:'new', stars:4 },
  { id:5, name:'Cookie Ustensiles', desc:'Décoré d\'ustensiles en sucre fondant, pour les amoureux de la pâtisserie.', price:4.00, icon:'🥄', bg:'bg-utensils', cat:'special', badge:'new', stars:4 },
  { id:6, name:'Cookie Kinder', desc:'Rempli de chocolat Kinder fondant et de morceaux de Bueno. Gourmandise XXL.', price:4.20, icon:'🍫', bg:'bg-kinder', cat:'choco', badge:'choc', stars:5 },
  { id:7, name:'Cookie Twix', desc:'Trozos de Twix caramelizado fundidos en una masa de cookie suave y crujiente. Dulce y adictiva.', price:4.20, icon:'🍫', bg:'bg-kinder', cat:'choco', badge:'new', stars:5 },
];

const builderList = [
  { id:'b1', name:'Lotus Noir',   icon:'🍪', price:3.50 },
  { id:'b2', name:'Lotus Blanc',  icon:'🤍', price:3.50 },
  { id:'b3', name:'Lacasitos',    icon:'🌈', price:3.80 },
  { id:'b4', name:'Fleurs',       icon:'🌸', price:4.00 },
  { id:'b5', name:'Ustensiles',   icon:'🥄', price:4.00 },
  { id:'b6', name:'Kinder',       icon:'🍫', price:4.20 },
  { id:'b7', name:'Twix',         icon:'🍫', price:4.20 },
];

let cart = [];
let builderSel = [];

function fmt(n){ return n.toFixed(2).replace('.',',') + ' €'; }

// ── CART ──
function updateCartUI(){
  const total = cart.reduce((s,i)=>s+i.price*i.qty,0);
  const items = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('cartBadge').textContent = items;
  document.getElementById('cartTotal').textContent = fmt(total);
  const c = document.getElementById('cartItems');
  if(!cart.length){ c.innerHTML='<div class="cart-empty-msg">Votre panier est vide.<br>Ajoutez de délicieux cookies !</div>'; return; }
  c.innerHTML = cart.map(item=>`
    <div class="cart-item">
      <div class="cart-item-icon">${item.icon}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">${fmt(item.price)} l'unité</div>
        <div class="cart-qty">
          <button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button>
          <span class="qty-num">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
        </div>
      </div>
      <div style="font-weight:700;color:var(--brown);font-size:.9rem">${fmt(item.price*item.qty)}</div>
    </div>
  `).join('');

  // update IG link with cart summary
  const summary = cart.map(i=>`${i.qty}x ${i.name}`).join(', ');
  const msg = encodeURIComponent(`Bonjour Amosa ! Je voudrais commander : ${summary}. Total : ${fmt(total)}. Pouvez-vous m'aider pour le paiement ? Merci 🍪`);
  document.getElementById('igCheckoutBtn').href = `https://www.instagram.com/direct/t/amosa.cookies/`;
}

function addToCart(id){
  const p = products.find(x=>x.id===id);
  const ex = cart.find(x=>x.id===id);
  if(ex) ex.qty++; else cart.push({...p,qty:1});
  updateCartUI();
  showToast(`🍪 ${p.name} ajouté au panier !`);
}

function changeQty(id,delta){
  const idx = cart.findIndex(x=>x.id===id);
  if(idx===-1) return;
  cart[idx].qty+=delta;
  if(cart[idx].qty<=0) cart.splice(idx,1);
  updateCartUI();
}

function toggleCart(){
  document.getElementById('cartDrawer').classList.toggle('open');
  document.getElementById('cartOverlay').classList.toggle('open');
}

// ── PRODUCTS ──
function renderProducts(filter='all'){
  const grid = document.getElementById('productsGrid');
  const list = filter==='all' ? products : products.filter(p=>p.cat===filter);
  grid.innerHTML = list.map(p=>`
    <div class="product-card">
      <div class="product-img ${p.bg}">
        <span>${p.icon}</span>
        ${p.badge ? `<div class="product-badge badge-${p.badge}">${p.badge==='fav'?'❤️ Favori':p.badge==='new'?'Nouveau':p.badge==='pack'?'📦 Pack':p.badge==='best'?'🏆 Más popular':'🍫 Choco'}</div>` : ''}
        ${p.qty ? `<div style="position:absolute;bottom:.7rem;right:.7rem;background:rgba(0,0,0,.55);color:white;border-radius:50px;padding:.2rem .7rem;font-size:.72rem;font-weight:700;">${p.qty} cookies</div>` : ''}
      </div>
      <div class="product-info">
        <div class="stars">${'★'.repeat(p.stars)}${'☆'.repeat(5-p.stars)}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <div>
            <div class="product-price">${fmt(p.price)}</div>
            ${p.qty ? `<div style="font-size:.72rem;color:var(--muted);">${fmt(p.price/p.qty)}/cookie</div>` : ''}
          </div>
          <button class="add-btn" onclick="addToCart(${p.id})">+</button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterProducts(cat,btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(cat);
}

// ── BUILDER ──
function renderBuilder(){
  document.getElementById('builderGrid').innerHTML = builderList.map(c=>`
    <div class="builder-item" id="bi-${c.id}" onclick="toggleBuilder('${c.id}')">
      <div class="check">✓</div>
      <div class="bi-icon">${c.icon}</div>
      <div class="bi-name">${c.name}</div>
      <div class="bi-price">${fmt(c.price)}</div>
    </div>
  `).join('');
}

function toggleBuilder(id){
  const c = builderList.find(x=>x.id===id);
  const idx = builderSel.findIndex(x=>x.id===id);
  if(idx>-1){
    builderSel.splice(idx,1);
    document.getElementById('bi-'+id).classList.remove('selected');
  } else {
    if(builderSel.length>=6){ showToast('Maximum 6 cookies par box 🍪'); return; }
    builderSel.push(c);
    document.getElementById('bi-'+id).classList.add('selected');
  }
  const total = builderSel.reduce((s,x)=>s+x.price,0);
  document.getElementById('builderTotal').textContent = fmt(total);
  const si = document.getElementById('summaryItems');
  if(!builderSel.length){ si.innerHTML='<div class="summary-empty">Sélectionne tes cookies préférés ✨</div>'; return; }
  si.innerHTML = builderSel.map(x=>`<div class="summary-cookie"><span>${x.icon} ${x.name}</span><span>${fmt(x.price)}</span></div>`).join('');
}

function addPackToCart(){
  if(!builderSel.length){ showToast('Sélectionne au moins un cookie !'); return; }
  const total = builderSel.reduce((s,c)=>s+c.price,0);
  const ex = cart.find(x=>x.id===9999);
  if(ex) ex.qty++;
  else cart.push({id:9999,name:`Box perso (${builderSel.length} cookies)`,icon:'🎁',price:total,qty:1});
  updateCartUI();
  showToast('🎁 Ta box a été ajoutée au panier !');
}

// ── NEWSLETTER ──
function subscribeNL(){
  const e = document.getElementById('nlEmail').value;
  if(!e||!e.includes('@')){ showToast('Saisis une adresse e-mail valide'); return; }
  sendNotification('newsletter', 'Email suscrito: ' + e);
  document.getElementById('nlOk').style.display='block';
  document.getElementById('nlEmail').value='';
  showToast('🎉 Bienvenue dans la famille Amosa !');
}

// ── TOAST ──
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

// ── CURSOR ──
const cursor=document.getElementById('cursor');
document.addEventListener('mousemove',e=>{ cursor.style.left=e.clientX+'px'; cursor.style.top=e.clientY+'px'; });
document.querySelectorAll('button,a,.product-card,.builder-item').forEach(el=>{
  el.addEventListener('mouseenter',()=>cursor.classList.add('big'));
  el.addEventListener('mouseleave',()=>cursor.classList.remove('big'));
});

// ── NAV ──
window.addEventListener('scroll',()=>{ document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>60); });

// ── REVEAL ──
const obs=new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{ if(e.isIntersecting) setTimeout(()=>e.target.classList.add('visible'),i*80); });
},{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ── EMAILJS CONFIG ──
// 🔧 CONFIGURACIÓN: Reemplaza estos valores con los tuyos de emailjs.com
const EMAILJS_PUBLIC_KEY  = 'TU_PUBLIC_KEY';    // Account → API Keys
const EMAILJS_SERVICE_ID  = 'TU_SERVICE_ID';    // Email Services → Service ID
const EMAILJS_TEMPLATE_ID = 'TU_TEMPLATE_ID';  // Email Templates → Template ID

emailjs.init({ publicKey: EMAILJS_PUBLIC_KEY });

function sendNotification(type, data) {
  const templates = {
    pedido:     '🛒 NUEVO PEDIDO en Amosa',
    newsletter: '💌 NUEVA SUSCRIPCIÓN Newsletter',
    resena:     '⭐ NUEVA RESEÑA en Amosa',
  };
  const params = {
    notification_type: templates[type] || type,
    details:           data,
    fecha:             new Date().toLocaleString('es-ES'),
    to_email:          'a.amosa.ch@gmail.com',
  };
  emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, params)
    .then(() => console.log('✅ Notificación enviada:', type))
    .catch(err => console.warn('⚠️ EmailJS error (configura tus claves):', err));
}

function toggleStar(n) {
  document.querySelectorAll('.star-btn').forEach((b, i) => {
    b.classList.toggle('selected', i < n);
  });
}

function submitResena() {
  const nombre = document.getElementById('resenaName').value.trim();
  const texto  = document.getElementById('resenaText').value.trim();
  const stars  = document.querySelectorAll('.star-btn.selected').length;
  if (!nombre || !texto) { showToast('Veuillez remplir votre prénom et commentaire'); return; }
  if (!stars) { showToast('Veuillez choisir une note ⭐'); return; }
  sendNotification('resena', 'De: ' + nombre + '\nValoración: ' + '⭐'.repeat(stars) + '\nComentario: ' + texto);
  const grid = document.querySelector('.avis-grid');
  const card = document.createElement('div');
  card.className = 'avis-card reveal visible';
  card.innerHTML = '<div class="avis-quote">"</div><p class="avis-text">' + texto + '</p><div class="avis-author"><div class="avis-avatar">😊</div><div><div class="avis-name">' + nombre + '</div><div class="avis-stars">' + '★'.repeat(stars) + '☆'.repeat(5-stars) + '</div></div></div>';
  grid.prepend(card);
  document.getElementById('resenaName').value = '';
  document.getElementById('resenaText').value = '';
  document.querySelectorAll('.star-btn').forEach(b => b.classList.remove('selected'));
  document.getElementById('resenaThanks').style.display = 'block';
  showToast('🙏 Merci pour votre avis !');
  setTimeout(() => document.getElementById('resenaThanks').style.display = 'none', 4000);
}

// ── INIT ──
renderProducts();
renderBuilder();
updateCartUI();

// Notificación al hacer checkout
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('igCheckoutBtn').addEventListener('click', function() {
    if (!cart.length) return;
    const summary = cart.map(i => i.qty + 'x ' + i.name + ' (' + fmt(i.price * i.qty) + ')').join('\n');
    const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
    sendNotification('pedido', 'Productos:\n' + summary + '\n\nTotal: ' + fmt(total));
  });
});
</script>
