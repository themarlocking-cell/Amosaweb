<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Amosa — Cookies Artisanaux</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --pink:       #E8A0B0;
    --pink-light: #F5D0DA;
    --pink-pale:  #FDF0F3;
    --brown:      #7B3A2A;
    --brown-mid:  #A0522D;
    --brown-dark: #4A1F10;
    --choco:      #3D1A08;
    --cream:      #FFF8F5;
    --muted:      #9A7070;
    --white:      #FFFFFF;
    --shadow:     0 8px 40px rgba(123,58,42,0.13);
    --shadow-lg:  0 24px 60px rgba(123,58,42,0.2);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Lato', sans-serif;
    background: var(--cream);
    color: var(--brown-dark);
    overflow-x: hidden;
  }

  /* ── CURSOR ── */
  .cursor {
    width: 10px; height: 10px;
    background: var(--pink);
    border-radius: 50%;
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 9999;
    transform: translate(-50%,-50%);
    transition: width .3s, height .3s, background .3s;
    mix-blend-mode: multiply;
  }
  .cursor.big { width: 44px; height: 44px; background: rgba(232,160,176,0.35); }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    padding: 1rem 5%;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(253,240,243,0.93);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(232,160,176,0.25);
    transition: box-shadow .3s;
  }
  nav.scrolled { box-shadow: var(--shadow); }

  .nav-logo img {
    height: 56px; width: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(123,58,42,0.15));
  }

  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--muted);
    font-size: 0.88rem; font-weight: 700;
    letter-spacing: 0.8px; text-transform: uppercase;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--brown); }

  .cart-btn {
    background: var(--brown); color: var(--cream);
    border: none; border-radius: 50px;
    padding: .55rem 1.3rem;
    font-family: 'Nunito', sans-serif;
    font-size: .85rem; font-weight: 700;
    cursor: pointer; transition: all .2s;
    display: flex; align-items: center; gap: .5rem;
  }
  .cart-btn:hover { background: var(--pink); color: var(--brown-dark); transform: translateY(-1px); }
  .cart-badge {
    background: var(--pink); color: var(--brown-dark);
    border-radius: 50%; width: 20px; height: 20px;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; font-weight: 900;
  }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: flex; align-items: center;
    padding: 7rem 5% 4rem;
    position: relative; overflow: hidden;
  }

  /* wavy pink bg */
  .hero-blob {
    position: absolute;
    border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%;
    background: var(--pink-light);
    opacity: .55;
    animation: blobmorph 10s ease-in-out infinite;
  }
  .hb1 { width: 700px; height: 700px; right: -200px; top: -150px; }
  .hb2 { width: 300px; height: 300px; left: 5%; bottom: 5%; opacity: .35; animation-delay: -4s; }
  @keyframes blobmorph {
    0%,100% { border-radius: 60% 40% 70% 30% / 50% 60% 40% 50%; }
    33%  { border-radius: 40% 60% 30% 70% / 60% 40% 60% 40%; }
    66%  { border-radius: 70% 30% 50% 50% / 30% 70% 50% 50%; }
  }

  .hero-content { position: relative; z-index: 2; max-width: 560px; }

  .hero-pill {
    display: inline-flex; align-items: center; gap: .5rem;
    background: rgba(232,160,176,.22);
    color: var(--brown); border-radius: 50px;
    padding: .4rem 1.1rem; font-size: .78rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .hero-pill::before { content: '🍪'; font-size: .9rem; }

  .hero-title {
    font-family: 'Nunito', sans-serif;
    font-size: clamp(2.6rem, 5.5vw, 5rem);
    line-height: 1.07; font-weight: 900;
    color: var(--brown-dark);
    margin-bottom: 1.4rem;
  }
  .hero-title em { color: var(--brown); font-style: italic; }

  .hero-sub {
    font-size: 1.05rem; color: var(--muted);
    line-height: 1.75; max-width: 440px;
    margin-bottom: 2.5rem;
  }

  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

  .btn-primary {
    background: var(--brown); color: var(--cream);
    border: none; border-radius: 50px;
    padding: .95rem 2.1rem; font-size: .95rem;
    font-family: 'Nunito', sans-serif; font-weight: 700;
    cursor: pointer; transition: all .25s; text-decoration: none;
    display: inline-flex; align-items: center; gap: .5rem;
  }
  .btn-primary:hover { background: var(--brown-mid); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(123,58,42,.3); }

  .btn-outline {
    background: transparent; color: var(--brown);
    border: 2px solid var(--pink); border-radius: 50px;
    padding: .95rem 2.1rem; font-size: .95rem;
    font-family: 'Nunito', sans-serif; font-weight: 700;
    cursor: pointer; transition: all .25s; text-decoration: none;
    display: inline-flex; align-items: center; gap: .5rem;
  }
  .btn-outline:hover { background: var(--pink-light); transform: translateY(-2px); }

  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 3rem;
    padding-top: 2rem; border-top: 1px solid rgba(123,58,42,.1);
  }
  .stat-num {
    font-family: 'Nunito', sans-serif;
    font-size: 2rem; font-weight: 900; color: var(--brown);
  }
  .stat-label { font-size: .78rem; color: var(--muted); margin-top: .15rem; }

  /* floating logo side */
  .hero-visual {
    position: absolute; right: 4%; top: 50%;
    transform: translateY(-50%);
    width: clamp(260px, 32vw, 480px);
    z-index: 2;
  }
  .logo-float {
    width: 100%;
    animation: float 7s ease-in-out infinite;
    filter: drop-shadow(0 20px 40px rgba(123,58,42,.25));
  }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }

  /* sprinkles */
  .sprinkle {
    position: absolute; border-radius: 50px;
    opacity: .55; animation: spin2 6s linear infinite;
  }
  @keyframes spin2 { from{transform:rotate(0)} to{transform:rotate(360deg)} }
  .sp1 { width: 18px; height: 6px; background: var(--pink); top: 20%; left: 10%; animation-duration: 8s; }
  .sp2 { width: 12px; height: 5px; background: var(--brown-mid); top: 70%; left: 55%; animation-duration: 6s; }
  .sp3 { width: 20px; height: 7px; background: #E8C07A; top: 40%; right: 38%; animation-duration: 10s; }
  .sp4 { width: 14px; height: 5px; background: var(--pink); top: 80%; right: 10%; animation-duration: 7s; }

  /* ── BAND ── */
  #band {
    background: var(--brown-dark); padding: 2.5rem 5%;
  }
  .band-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 1.5rem;
  }
  .band-item {
    display: flex; align-items: center; gap: 1rem; color: rgba(255,248,245,.8);
  }
  .band-icon {
    font-size: 1.6rem;
    background: rgba(232,160,176,.15); width: 46px; height: 46px;
    border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .band-item h4 { color: var(--pink-light); font-size: .9rem; font-weight: 700; margin-bottom: .2rem; }
  .band-item p { font-size: .78rem; color: rgba(255,248,245,.5); line-height: 1.4; }

  /* ── SECTION COMMON ── */
  section { padding: 6rem 5%; }
  .section-tag {
    display: inline-block; color: var(--pink);
    font-size: .78rem; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; margin-bottom: .7rem;
  }
  .section-title {
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    color: var(--brown-dark); line-height: 1.15; margin-bottom: .9rem;
  }
  .section-sub { color: var(--muted); font-size: 1rem; max-width: 500px; line-height: 1.7; }
  .section-header { margin-bottom: 3rem; }

  /* ── PRODUCTS ── */
  #produits { background: white; }

  .filter-bar { display: flex; gap: .6rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .filter-btn {
    background: transparent;
    border: 1.5px solid rgba(123,58,42,.15);
    border-radius: 50px; padding: .42rem 1.1rem;
    font-size: .82rem; font-weight: 700; color: var(--muted);
    cursor: pointer; transition: all .2s;
    font-family: 'Lato', sans-serif;
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--brown-dark); color: var(--cream); border-color: var(--brown-dark);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(265px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    background: var(--cream); border-radius: 24px; overflow: hidden;
    transition: transform .3s, box-shadow .3s; cursor: pointer; position: relative;
  }
  .product-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-lg); }

  .product-img {
    aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
    font-size: 5.5rem; position: relative; overflow: hidden;
  }

  /* each product unique bg */
  .bg-lotus    { background: linear-gradient(135deg, #F5DEB3 0%, #DEB887 100%); }
  .bg-lotus-w  { background: linear-gradient(135deg, #FFF8F0 0%, #F5E6D0 100%); }
  .bg-lacasito { background: linear-gradient(135deg, #FFE4F0 0%, #FECFE0 100%); }
  .bg-flores   { background: linear-gradient(135deg, #FFF0F5 0%, #FFD6E7 100%); }
  .bg-utensils { background: linear-gradient(135deg, #E8F4FD 0%, #CDDFF7 100%); }
  .bg-kinder   { background: linear-gradient(135deg, #FFF3CD 0%, #FFE082 100%); }
  .bg-pack-s   { background: linear-gradient(135deg, #FFE0F0 0%, #FFADD2 100%); }
  .bg-pack-m   { background: linear-gradient(135deg, #E8D5FF 0%, #C8A0F0 100%); }
  .bg-pack-l   { background: linear-gradient(135deg, #FFD5A8 0%, #FFB066 100%); }

  .product-badge {
    position: absolute; top: 1rem; left: 1rem;
    background: var(--brown); color: white;
    font-size: .68rem; font-weight: 700;
    padding: .25rem .75rem; border-radius: 50px;
    text-transform: uppercase; letter-spacing: .5px;
  }
  .badge-fav   { background: var(--pink); color: var(--brown-dark); }
  .badge-new   { background: #27AE60; }
  .badge-choc  { background: var(--choco); }
  .badge-pack  { background: #8B5CF6; }
  .badge-best  { background: #F59E0B; color: var(--brown-dark); }

  .product-info { padding: 1.3rem 1.5rem 1.5rem; }
  .product-name {
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: 1.15rem; color: var(--brown-dark); margin-bottom: .35rem;
  }
  .product-desc { font-size: .82rem; color: var(--muted); margin-bottom: 1rem; line-height: 1.55; }
  .product-footer { display: flex; align-items: center; justify-content: space-between; }
  .product-price {
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: 1.3rem; color: var(--brown);
  }
  .stars { color: var(--pink); font-size: .8rem; margin-bottom: .45rem; }

  .add-btn {
    background: var(--brown-dark); color: var(--cream);
    border: none; border-radius: 50px;
    width: 40px; height: 40px; font-size: 1.3rem;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all .2s;
  }
  .add-btn:hover { background: var(--pink); color: var(--brown-dark); transform: scale(1.1) rotate(90deg); }

  /* ── PERSONALISE ── */
  #personalise { background: var(--pink-pale); }
  .builder-wrap {
    display: grid; grid-template-columns: 1fr 340px; gap: 3rem; align-items: start;
  }
  @media(max-width:900px){ .builder-wrap{grid-template-columns:1fr;} }

  .builder-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem;
  }
  .builder-item {
    background: white; border: 2px solid transparent;
    border-radius: 18px; padding: 1.2rem;
    text-align: center; cursor: pointer;
    transition: all .2s; position: relative;
  }
  .builder-item:hover { border-color: rgba(232,160,176,.5); }
  .builder-item.selected { border-color: var(--pink); background: rgba(232,160,176,.08); }
  .builder-item .bi-icon { font-size: 2.8rem; margin-bottom: .45rem; }
  .builder-item .bi-name { font-size: .8rem; font-weight: 700; color: var(--brown-dark); }
  .builder-item .bi-price { font-size: .72rem; color: var(--muted); }
  .builder-item .check {
    position: absolute; top: 8px; right: 8px;
    width: 22px; height: 22px;
    background: var(--pink); border-radius: 50%;
    display: none; align-items: center; justify-content: center;
    color: white; font-size: .7rem; font-weight: 900;
  }
  .builder-item.selected .check { display: flex; }

  .builder-summary {
    background: var(--brown-dark); color: var(--cream);
    border-radius: 24px; padding: 2rem; position: sticky; top: 6rem;
  }
  .summary-title {
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: 1.25rem; margin-bottom: 1.5rem;
  }
  .summary-items { min-height: 100px; margin-bottom: 1.5rem; }
  .summary-empty { color: rgba(255,248,245,.35); font-size: .85rem; text-align: center; padding: 1.5rem; }
  .summary-cookie {
    display: flex; justify-content: space-between;
    padding: .55rem 0; border-bottom: 1px solid rgba(255,248,245,.08);
    font-size: .83rem;
  }
  .summary-total {
    display: flex; justify-content: space-between;
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: 1.25rem; color: var(--pink); margin-bottom: 1.2rem;
  }
  .btn-summary {
    width: 100%; background: var(--pink); color: var(--brown-dark);
    border: none; border-radius: 50px; padding: 1rem;
    font-size: .95rem; font-weight: 700; cursor: pointer;
    font-family: 'Nunito', sans-serif; transition: all .2s;
  }
  .btn-summary:hover { background: var(--pink-light); }

  /* ── ABOUT ── */
  #apropos {
    display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
    background: white;
  }
  @media(max-width:768px){ #apropos{grid-template-columns:1fr;gap:2rem;} }

  .apropos-cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  .apropos-card {
    background: var(--pink-pale); border-radius: 20px; padding: 1.5rem;
    text-align: center; transition: transform .3s;
  }
  .apropos-card:hover { transform: translateY(-4px); }
  .apropos-card .icon { font-size: 2.2rem; margin-bottom: .7rem; }
  .apropos-card h4 {
    font-family: 'Nunito', sans-serif; font-weight: 900;
    font-size: .95rem; color: var(--brown-dark); margin-bottom: .3rem;
  }
  .apropos-card p { font-size: .78rem; color: var(--muted); line-height: 1.5; }

  .step-list { display: flex; flex-direction: column; gap: 1.3rem; margin-top: 2rem; }
  .step-item { display: flex; gap: 1rem; align-items: flex-start; }
  .step-num {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--pink); color: var(--brown-dark);
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: .82rem; flex-shrink: 0;
    font-family: 'Nunito', sans-serif;
  }
  .step-item strong { color: var(--brown-dark); font-size: .93rem; }
  .step-item span { color: var(--muted); font-size: .83rem; display: block; margin-top: .2rem; }

  /* ── AVIS ── */
  #avis { background: var(--cream); }
  .avis-grid {
    display: grid; grid-template-columns: repeat(auto-fill,minmax(290px,1fr)); gap: 1.5rem;
  }
  .avis-card {
    background: white; border-radius: 22px; padding: 1.8rem;
    box-shadow: var(--shadow); transition: transform .3s;
  }
  .avis-card:hover { transform: translateY(-4px); }
  .avis-quote {
    font-family: 'Nunito', sans-serif; font-size: 3.5rem;
    color: var(--pink); line-height: 1; margin-bottom: .3rem;
  }
  .avis-text { font-size: .92rem; color: var(--brown-dark); line-height: 1.7; margin-bottom: 1.3rem; }
  .avis-author { display: flex; align-items: center; gap: .8rem; }
  .avis-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--pink-pale); display: flex; align-items: center;
    justify-content: center; font-size: 1.5rem;
  }
  .avis-name { font-weight: 700; font-size: .88rem; color: var(--brown-dark); }
  .avis-stars { color: var(--pink); font-size: .8rem; }

  /* ── NEWSLETTER ── */
  #newsletter { background: var(--pink); padding: 5rem 5%; text-align: center; }
  #newsletter .section-tag { color: rgba(74,31,16,.6); }
  #newsletter .section-title { color: var(--brown-dark); }
  #newsletter .section-sub { color: rgba(74,31,16,.7); margin: 0 auto 2rem; }
  .nl-form {
    display: flex; gap: .8rem; max-width: 460px;
    margin: 0 auto; flex-wrap: wrap; justify-content: center;
  }
  .nl-form input {
    flex: 1; min-width: 220px; border: none; border-radius: 50px;
    padding: .88rem 1.5rem; font-size: .9rem;
    font-family: 'Lato', sans-serif;
    background: rgba(255,255,255,.55); color: var(--brown-dark); outline: none;
  }
  .nl-form input::placeholder { color: rgba(74,31,16,.45); }
  .nl-form input:focus { background: rgba(255,255,255,.75); }
  .nl-form button {
    background: var(--brown-dark); color: var(--cream);
    border: none; border-radius: 50px;
    padding: .88rem 1.8rem; font-size: .9rem; font-weight: 700;
    font-family: 'Nunito', sans-serif; cursor: pointer; transition: all .2s;
  }
  .nl-form button:hover { background: var(--choco); }
  .nl-ok { color: var(--brown-dark); font-size: .88rem; font-weight: 700; margin-top: 1rem; display: none; }

  /* ── FOOTER ── */
  footer { background: var(--choco); color: rgba(255,248,245,.65); padding: 4rem 5% 2rem; }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem;
  }
  @media(max-width:768px){ .footer-grid{grid-template-columns:1fr 1fr;} }
  .footer-logo img { height: 60px; margin-bottom: 1rem; }
  .footer-desc { font-size: .83rem; line-height: 1.7; max-width: 260px; }
  .footer-col h5 {
    color: var(--pink-light); font-size: .8rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 1.2rem;
  }
  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: .6rem; }
  .footer-col ul a {
    text-decoration: none; color: rgba(255,248,245,.5);
    font-size: .83rem; transition: color .2s;
  }
  .footer-col ul a:hover { color: var(--pink); }
  .footer-bottom {
    border-top: 1px solid rgba(255,248,245,.08); padding-top: 1.5rem;
    display: flex; justify-content: space-between; font-size: .78rem; flex-wrap: wrap; gap: .5rem;
  }

  /* ── CART DRAWER ── */
  .cart-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,.45);
    z-index: 200; opacity: 0; pointer-events: none; transition: opacity .3s;
  }
  .cart-overlay.open { opacity: 1; pointer-events: all; }
  .cart-drawer {
    position: fixed; right: 0; top: 0; bottom: 0; width: 380px; max-width: 100%;
    background: var(--cream); z-index: 201;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    display: flex; flex-direction: column;
    box-shadow: -20px 0 60px rgba(0,0,0,.12);
  }
  .cart-drawer.open { transform: translateX(0); }
  .cart-head {
    padding: 1.5rem; border-bottom: 1px solid rgba(123,58,42,.1);
    display: flex; justify-content: space-between; align-items: center;
  }
  .cart-head h3 { font-family: 'Nunito', sans-serif; font-weight: 900; font-size: 1.4rem; color: var(--brown-dark); }
  .close-cart { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--muted); transition: color .2s; }
  .close-cart:hover { color: var(--brown); }
  .cart-items { flex: 1; overflow-y: auto; padding: 1rem 1.5rem; }
  .cart-item { display: flex; gap: 1rem; align-items: center; padding: 1rem 0; border-bottom: 1px solid rgba(123,58,42,.07); }
  .cart-item-icon { font-size: 2.2rem; }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-weight: 700; font-size: .9rem; color: var(--brown-dark); }
  .cart-item-price { font-size: .8rem; color: var(--muted); }
  .cart-qty { display: flex; align-items: center; gap: .5rem; margin-top: .35rem; }
  .qty-btn {
    background: var(--pink-light); border: none; width: 24px; height: 24px;
    border-radius: 50%; cursor: pointer; font-size: .9rem;
